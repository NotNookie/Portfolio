---
import { profile, coreStack } from "../data/site";
---

<section
  class="relative min-h-[90vh] flex items-center dot-grid border-b border-outline-variant"
  id="hero"
>
  <div
    class="max-w-7xl mx-auto px-container-padding w-full grid grid-cols-1 lg:grid-cols-2 gap-16 py-20 items-center"
  >
    <div class="space-y-8">
      <div class="space-y-4">
        <h1 class="font-headline-xl text-headline-xl text-on-surface">
          Hi, I'm <br />
          <span class="text-primary">{profile.name}</span>
        </h1>
        <p
          class="flex items-center gap-2 font-code-label text-code-label text-on-surface-variant"
        >
          <span class="text-primary" aria-hidden="true">&gt;</span> {profile.role}<span
            class="animate-pulse"
            aria-hidden="true">|</span
          >
        </p>
      </div>
      <p class="text-body-md text-on-surface-variant max-w-xl">
        {profile.tagline}
      </p>

      <div class="space-y-4 pt-4 border-t border-outline-variant border-dashed">
        <div
          class="font-code-label text-[10px] uppercase text-on-surface-variant flex items-center gap-2"
        >
          <span class="material-symbols-outlined text-sm" aria-hidden="true"
            >terminal</span
          > CORE STACK
        </div>
        <ul class="flex flex-wrap gap-2">
          {
            coreStack.map((tech) => (
              <li class="bg-surface-container-low px-2 py-1 border border-outline-variant text-[11px] font-code-label">
                {tech}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="p-4 border border-outline-variant bg-surface-container-low space-y-1">
          <div
            class="flex items-center gap-2 font-code-label text-[10px] uppercase text-on-surface-variant"
          >
            <span class="material-symbols-outlined text-sm" aria-hidden="true"
              >location_on</span
            > LOCATION
          </div>
          <div class="font-body-md font-medium">{profile.location}</div>
        </div>
        <div class="p-4 border border-outline-variant bg-surface-container-low space-y-1">
          <div
            class="flex items-center gap-2 font-code-label text-[10px] uppercase text-on-surface-variant"
          >
            <span class="material-symbols-outlined text-sm" aria-hidden="true">mail</span> EMAIL
          </div>
          <div class="font-body-md font-medium">{profile.email}</div>
        </div>
      </div>

      <div class="flex flex-wrap gap-4 pt-4">
        <a
          href="#projects"
          class="bg-primary text-on-primary px-8 py-4 font-bold flex items-center gap-2 hover:translate-x-1 transition-transform"
        >
          View work <span class="material-symbols-outlined" aria-hidden="true">south</span>
        </a>
        <a
          href="#contact"
          class="border border-primary text-primary px-8 py-4 font-bold flex items-center gap-2 hover:bg-surface-container transition-colors"
        >
          <span class="material-symbols-outlined" aria-hidden="true">auto_awesome</span> Let's talk
        </a>
      </div>
    </div>

    <div class="relative">
      <div
        class="bg-surface border border-outline-variant rounded-lg overflow-hidden window-shadow"
      >
        <div
          class="bg-surface-container-high px-4 py-2 flex items-center gap-2 border-b border-outline-variant"
        >
          <div class="flex gap-1.5" aria-hidden="true">
            <div class="w-3 h-3 rounded-full bg-[#FF5F56]"></div>
            <div class="w-3 h-3 rounded-full bg-[#FFBD2E]"></div>
            <div class="w-3 h-3 rounded-full bg-[#27C93F]"></div>
          </div>
          <div class="text-[12px] font-code-label text-on-surface-variant ml-4">
            ~/about.js
          </div>
        </div>
        <div class="p-6 font-code-label text-code-label leading-relaxed">
          <pre class="whitespace-pre-wrap"><code><span class="text-[#D33682]">const</span> dev <span class="text-on-surface-variant">=</span> {"{"}
  name: <span class="text-[#2AA198]">"{profile.name}"</span>,
  role: <span class="text-[#2AA198]">"{profile.role}"</span>,
  location: <span class="text-[#2AA198]">"{profile.location}"</span>,
  stack: [<span class="text-[#2AA198]">"React"</span>, <span class="text-[#2AA198]">"Node"</span>, <span class="text-[#2AA198]">"Astro"</span>],
  focus: <span class="text-[#2AA198]">"End-to-End Products"</span>
{"}"};</code></pre>
        </div>
      </div>
      <div
        class="absolute -z-10 -bottom-10 -right-10 w-64 h-64 border border-outline-variant border-dashed"
        aria-hidden="true"
      >
      </div>
    </div>
  </div>
</section>
