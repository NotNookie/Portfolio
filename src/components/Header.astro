---
const navLinks = [
  { href: "#projects", label: "projects" },
  { href: "#contact", label: "contact" },
];
---

<header
  class="fixed top-0 w-full z-50 bg-background/80 backdrop-blur-sm border-b border-outline-variant"
>
  <div
    class="flex justify-between items-center h-16 px-container-padding max-w-7xl mx-auto w-full"
  >
    <a
      href="#hero"
      class="font-code-label text-code-label text-on-surface tracking-wider font-bold nav-link"
    >
      ./Nookie
    </a>
    <nav class="hidden md:flex gap-gutter items-center" aria-label="Primary">
      {
        navLinks.map((link) => (
          <a
            class="nav-link font-code-label text-code-label uppercase tracking-wider text-on-surface-variant hover:text-primary transition-colors"
            href={link.href}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="/resume.pdf"
        class="bg-primary text-on-primary px-6 py-2 font-code-label text-code-label uppercase tracking-widest hover:opacity-90 transition-all ml-4"
      >
        Resume
      </a>
    </nav>
    <button
      class="md:hidden"
      id="mobile-menu-toggle"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="material-symbols-outlined" aria-hidden="true">menu</span>
    </button>
  </div>
  <nav
    id="mobile-menu"
    class="md:hidden hidden flex-col gap-1 px-container-padding pb-4 border-t border-outline-variant"
    aria-label="Mobile"
  >
    {
      navLinks.map((link) => (
        <a
          class="nav-link font-code-label text-code-label uppercase tracking-wider text-on-surface-variant hover:text-primary transition-colors py-2"
          href={link.href}
        >
          {link.label}
        </a>
      ))
    }
    <a
      href="/resume.pdf"
      class="bg-primary text-on-primary px-6 py-2 font-code-label text-code-label uppercase tracking-widest hover:opacity-90 transition-all mt-2 text-center"
    >
      Resume
    </a>
  </nav>
</header>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");

  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(isOpen));
    menu?.classList.toggle("flex", isOpen);
  });

  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
      menu.classList.remove("flex");
      toggle?.setAttribute("aria-expanded", "false");
    });
  });

  const navLinks = document.querySelectorAll<HTMLAnchorElement>(".nav-link");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute("id");
          navLinks.forEach((link) => {
            link.classList.remove(
              "text-primary",
              "font-bold",
              "border-b",
              "border-primary",
              "pb-1"
            );
            if (link.getAttribute("href") === `#${id}`) {
              link.classList.add(
                "text-primary",
                "font-bold",
                "border-b",
                "border-primary",
                "pb-1"
              );
            }
          });
        }
      });
    },
    { threshold: 0.5 }
  );

  document.querySelectorAll("section[id]").forEach((section) => {
    observer.observe(section);
  });

  navLinks.forEach((link) => {
    link.addEventListener("click", (e) => {
      const href = link.getAttribute("href");
      if (!href || !href.startsWith("#")) return;
      const target = document.querySelector(href);
      if (target instanceof HTMLElement) {
        e.preventDefault();
        window.scrollTo({
          top: target.offsetTop - 64,
          behavior: "smooth",
        });
      }
    });
  });
</script>
