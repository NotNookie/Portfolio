---
import { profile } from "../data/site";

const year = new Date().getFullYear();
const links = [
  { label: "github", href: profile.github },
  { label: "linkedin", href: profile.linkedin },
  { label: "source", href: "https://github.com/NotNookie/Portfolio" },
];
---

<footer class="bg-surface-container dark:bg-tertiary-container border-t border-outline-variant">
  <div
    class="flex flex-col md:flex-row justify-between items-center px-container-padding py-12 max-w-7xl mx-auto w-full gap-8"
  >
    <div class="space-y-2 text-center md:text-left">
      <p class="font-headline-lg text-headline-lg text-on-surface">LPMS</p>
      <p class="font-code-comment text-code-comment text-on-surface-variant">
        &copy; {year} Built with systematic clarity.
      </p>
    </div>
    <nav class="flex gap-gutter items-center" aria-label="Footer">
      {
        links.map((link) => (
          <a
            class="font-code-comment text-code-comment text-on-surface-variant hover:text-primary underline decoration-dashed"
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
          >
            {link.label}
          </a>
        ))
      }
    </nav>
    <p class="text-[10px] font-code-label text-on-surface-variant uppercase tracking-[0.2em]">
      Built with Care | v1.0
    </p>
  </div>
</footer>
